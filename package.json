{
  "name": "bank-transaction-system",
  "version": "1.0.0",
  "description": "Full-stack banking transaction system with React frontend and Node.js backend",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../client && npm install",
    "start-backend": "cd backend && npm run dev",
    "start-frontend": "cd client && npm run dev",
    "build-frontend": "cd client && npm run build",
    "dev": "concurrently \"npm run start-backend\" \"npm run start-frontend\"",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": [
    "banking",
    "transactions",
    "ledger",
    "mern",
    "full-stack"
  ],
  "author": "Tarun Singodia",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "backend",
    "client"
  ]
}